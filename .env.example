# Copy to .env in repo root for docker compose, or set in hosting dashboard.
# Generate: openssl rand -hex 32

JWT_SECRET=change-me-min-32-chars
ENCRYPTION_KEY=change-me-same-as-local-so-mailbox-passwords-decrypt

# Where the browser opens the app (CORS). Several origins — comma, no space after comma is ok:
# FRONTEND_URL=https://mail-checker-rho.vercel.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Optional overrides
# MAIL_CHECK_CRON=*/5 * * * *
# MAX_UNSEEN_PER_MAILBOX=10
